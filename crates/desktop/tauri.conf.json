{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tessera",
  "version": "0.1.0",
  "identifier": "com.tessera.dev",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "beforeBuildCommand": "corepack pnpm build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tessera",
        "width": 1100,
        "height": 760,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["src/assets/tessera-logo-parchment.svg"]
  }
}
